# Required.
TOKEN=replace-me

# Optional runtime settings.
DB_PATH=data/marginalia.db
PORT=9595
OWNER=
THEME=terminal

# Optional auth hardening.
# Set to true to enable temporary lockouts after repeated invalid tokens.
AUTH_RATE_LIMIT=false

# Optional proxy-awareness for auth throttling and denial logs.
# Leave disabled unless Marginalia sits behind a proxy you control.
TRUST_PROXY=false

# Comma-separated header priority used only when TRUST_PROXY=true.
REAL_IP_HEADERS=CF-Connecting-IP,True-Client-IP,X-Real-IP,X-Forwarded-For

# Optional comma-separated proxy IPs or CIDRs trusted to supply the headers above.
# Example: 203.0.113.10,203.0.113.0/24
TRUSTED_PROXIES=

# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317